% coloura is the border colour, colourb will be set to 20% opacity
% and become the background colour.
\def\resultcoloura{copperrose}
\def\resultcolourb{copperrose}
\def\followupcoloura{ashgrey}
\def\followupcolourb{ashgrey}
\def\presumptioncoloura{denim}
\def\presumptioncolourb{denim}
\def\questioncolour{ashgrey}
% ---------------------- Major Results ----------------------
% Theorems:
\mdfdefinestyle{thmframe}{
    backgroundcolor=\resultcolourb!20,
    linecolor=\resultcoloura,
    linewidth=3pt,%
    nobreak=true
}
\mdfapptodefinestyle{thmframe}{
    topline=false,
    bottomline=false
}
\surroundwithmdframed[style=thmframe]{theorem}
% Propositions:
\mdfdefinestyle{propframe}{
    backgroundcolor=\resultcolourb!20,
    linecolor=\resultcoloura,
    linewidth=3pt,%
    nobreak=true
}
\mdfapptodefinestyle{propframe}{
    topline=false,
    rightline=false,
    bottomline=false
}
\surroundwithmdframed[style=propframe]{proposition}
% Lemmas:
