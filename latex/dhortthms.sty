% -----------------------------------------------------------
%                        amsthm styles
% -----------------------------------------------------------
% Notes and remarks use amsthmstyle2
% Everything else uses amsthmstyle1

% ---------------- Theorem Style Definitions ----------------
% AMS Theorem Style 1:
\newtheoremstyle
    {amsthmstyle1}% name
    {3pt}% Space above
    {3pt}% Space below
    {}% Body font
    {}% Indent amount
    {\bfseries}% Theorem head font
    {:}% Punctuation after theorem head
    {.5em}% Space after theorem head
    {}% Theorem head spec (can be left empty, meaning ‘normal’)
% AMS Theorem Stlye 2:
\newtheoremstyle
    {amsthmstyle2}% name
    {3pt}% Space above
    {3pt}% Space below
    {}% Body font
    {}% Indent amount
    {\itshape}% Theorem head font
    {:}% Punctuation after theorem head
    {.5em}% Space after theorem head
    {}% Theorem head spec (can be left empty, meaning ‘normal’)

% ----------------- Environment Definitions -----------------
% Theorem Stlye 1:
\theoremstyle{amsthmstyle1}
\newtheorem{theorem}{Theorem}[section]
\newtheorem{proposition}[theorem]{Proposition}
\newtheorem{lemma}[theorem]{Lemma}
\newtheorem{claim}{Claim}[theorem]
\newtheorem{corollary}[claim]{Corollary}
\newtheorem{definition}{Definition}[section]
\newtheorem{notation}[definition]{Notation}
\newtheorem{example}{Example}[section]

% Theorem Style 2:
\theoremstyle{amsthmstyle2}
\newtheorem*{remark}{Remark}
\newtheorem*{note}{Note}
\newtheorem{question}




% -----------------------------------------------------------
%                       mdframed styles
% -----------------------------------------------------------
% Colour Legend:
% | Colour | Interpretation | Uses ordered by decreasing importance  |
% | Blue   | Major Result   | Theorems, Propositions, Lemmas, Claims |
% | Green  | Follow Up      | Corollaries, Examples, Notes, Remarks  |
% | Red    | Presumption    | Axioms, Definitions, Notations         |

% Colours taken from https://latexcolor.com
\definecolor{mediumpersianblue}{rgb}{0.0, 0.4, 0.65}
\definecolor{limegreen}{rgb}{0.2, 0.8, 0.2}
\definecolor{orange-red}{rgb}{1.0, 0.27, 0.0}
\definecolor{cadmiumred}{rgb}{0.89, 0.0, 0.13}
\definecolor{ballblue}{rgb}{0.13, 0.67, 0.8}
\definecolor{asparagus}{rgb}{0.53, 0.66, 0.42}
\definecolor{ashgrey}{rgb}{0.7, 0.75, 0.71}
\definecolor{airforceblue}{rgb}{0.36, 0.54, 0.66}
\definecolor{darkpastelblue}{rgb}{0.47, 0.62, 0.8}
